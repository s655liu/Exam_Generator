{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "data/*.json",
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|data).*)",
      "destination": "/index.html"
    }
  ]
}